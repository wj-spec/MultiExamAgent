# IntelliExam-Agent 环境配置

# OpenAI API 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1

# 如果使用 DeepSeek
# OPENAI_API_BASE=https://api.deepseek.com/v1
# OPENAI_API_KEY=your_deepseek_api_key_here

# 模型配置
DEFAULT_MODEL=gpt-4o-mini

# ===========================================
# Embedding 模型配置
# ===========================================
# 支持的 provider: openai, dashscope, huggingface, ollama
EMBEDDING_PROVIDER=openai

# OpenAI Embedding 模型（当 EMBEDDING_PROVIDER=openai 时使用）
# 可选模型: text-embedding-ada-002, text-embedding-3-small, text-embedding-3-large
EMBEDDING_MODEL=text-embedding-3-small

# 如果 embedding 使用不同的 API Key，可以单独配置（留空则使用 OPENAI_API_KEY）
# EMBEDDING_API_KEY=your_embedding_api_key
# EMBEDDING_API_BASE=https://api.openai.com/v1

# 阿里云灵积（通义）Embedding 配置示例
# EMBEDDING_PROVIDER=dashscope
# EMBEDDING_MODEL=text-embedding-v2
# DASHSCOPE_API_KEY=your_dashscope_api_key

# HuggingFace 本地模型配置示例（无需 API Key）
# EMBEDDING_PROVIDER=huggingface
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Ollama 本地模型配置示例
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_API_BASE=http://localhost:11434

# 向量数据库配置
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# 日志级别
LOG_LEVEL=INFO

# ===========================================
# 多源检索配置
# ===========================================

# Tavily 搜索 API (可选，用于高质量网络搜索)
TAVILY_API_KEY=your_tavily_api_key_here

# ===========================================
# Reranker 重排序配置
# ===========================================
# 支持的 provider: none, cohere, huggingface, llm
# none - 禁用 Reranker
# cohere - 使用 Cohere 云 API
# huggingface - 使用本地 HuggingFace 模型
# llm - 使用 LLM 进行重排序
RERANKER_PROVIDER=none

# Cohere Reranker 配置 (当 RERANKER_PROVIDER=cohere 时使用)
COHERE_API_KEY=your_cohere_api_key_here

# HuggingFace Reranker 模型 (当 RERANKER_PROVIDER=huggingface 时使用)
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Browser Agent 配置
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000
